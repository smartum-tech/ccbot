# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Claude command to run in new windows (optional, defaults to "claude")
CLAUDE_COMMAND=claude

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Custom shell commands (executed directly via subprocess)
# Format: CUSTOM_CMD_<name>=<shell command>
# CUSTOM_CMD_DEPLOY=npm run build
# CUSTOM_CMD_RESTART=systemctl restart myapp

# Claude Code skill shortcuts (forwarded to CC, shown in Telegram menu)
# Format: CC_CMD_<name>=<description for menu>
# CC_CMD_COMMIT=Create a git commit
# CC_CMD_SIMPLIFY=Review and simplify code
