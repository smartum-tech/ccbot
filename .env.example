# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Restrict this bot instance to a single Telegram chat (optional)
# Use for multi-instance setups sharing one bot token
# CHAT_ID=-100123456789

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Claude command to run in new windows (optional, defaults to "claude")
CLAUDE_COMMAND=claude

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Custom shell commands (executed directly via subprocess)
# Format: CUSTOM_CMD_<name>=<shell command>
# CUSTOM_CMD_DEPLOY=npm run build
# CUSTOM_CMD_RESTART=systemctl restart myapp

# Prefix messages to Claude Code with sender's Telegram name (optional)
# CCBOT_SHOW_AUTHOR=true

# Claude Code skill shortcuts (forwarded to CC, shown in Telegram menu)
# Format: CC_CMD_<name>=<description for menu>
# CC_CMD_COMMIT=Create a git commit
# CC_CMD_SIMPLIFY=Review and simplify code

# Restrict directory browser to a root directory (optional)
# When set, users can only browse within this directory subtree
# CCBOT_ROOT_DIR=/home/user/projects

# Docker-based Claude Code
# Use {CCBOT_WINDOW_KEY} and {CCBOT_MAP_FILE} placeholders — they are substituted at runtime.
# Install the Docker hook first: ccbot hook --install-docker --claude-config-dir /path/to/.claude
# CLAUDE_COMMAND=docker run -it --rm -e CCBOT_WINDOW_KEY={CCBOT_WINDOW_KEY} -e CCBOT_MAP_FILE=/root/.ccbot/session_map.json -v /path/to/ccbot-dir:/root/.ccbot -v /path/to/.claude:/root/.claude -v $PWD:/workspace -w /workspace claude-code

# Container-side mount point for ccbot_dir (for file/image path translation)
# Set this when Claude Code runs in Docker so attached files use container paths.
# CCBOT_CONTAINER_DIR=/root/.ccbot
